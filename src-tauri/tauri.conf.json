{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RPGAtlas",
  "version": "0.1.0",
  "identifier": "com.rpgatlas.editor",
  "build": {
    "frontendDist": "dist",
    "beforeDevCommand": "node scripts/stage-frontend.mjs",
    "beforeBuildCommand": "node scripts/stage-frontend.mjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "RPGAtlas Desktop",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "useHttpsScheme": true,
        "resizable": true
      },
      {
        "label": "playtest",
        "title": "RPGAtlas — Playtest",
        "url": "play.html",
        "width": 816,
        "height": 624,
        "visible": false,
        "useHttpsScheme": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"]
  }
}
